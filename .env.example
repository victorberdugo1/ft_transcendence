# ─── Base de datos ───────────────────────────────────────────
DB_USER=transcendence
DB_PASSWORD=cambia_esto_en_produccion
DB_NAME=transcendence_db
DB_HOST=db
DB_PORT=5432

# ─── Backend ─────────────────────────────────────────────────
NODE_ENV=development
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
PORT=3000

# ─── Juego ───────────────────────────────────────────────────
GAME_TICK_RATE=60        # fps del game loop del servidor
SCREEN_WIDTH=800
SCREEN_HEIGHT=600

